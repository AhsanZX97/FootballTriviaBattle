# Production build: point the app at the deployed Render WebSocket server.
# Vite bakes this in at build time. Used by debug native builds
# (npm run android) and the Vercel web build; Vercel also sets the same value
# in its dashboard, so the two agree. Play Store bundles are built with
# `npm run cap:sync:release` instead, which loads .env.release (real ad IDs).
# No VITE_ADMOB_BANNER_ID here: production-mode builds serve AdMob TEST ads.
VITE_WS_URL=wss://football-trivia-ws.onrender.com

# Supabase project (accounts + coins). Anon key is public-safe to bake in.
