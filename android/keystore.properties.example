# Copy this to `android/keystore.properties` (gitignored) and fill in your
# values. build.gradle reads it to sign the release .aab.
#
# storeFile: absolute path to your upload keystore (.jks). Keep the .jks OUTSIDE
#   the repo so it can never be committed. Use forward slashes even on Windows.
storeFile=C:/Users/ahsan/keys/upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
