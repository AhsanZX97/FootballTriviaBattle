# Release-only build config, used by `npm run build:release` / `cap:sync:release`
# (vite --mode release). The real AdMob ad unit ID lives ONLY here so every
# other build — dev server, debug `npm run android` APKs, the Vercel web build —
# falls back to Google's test ads. Clicking real ads on your own device is how
# AdMob accounts get flagged, so never copy this ID into another env file.
#
# Note: mode `release` does NOT load .env.production, so VITE_WS_URL must be
# repeated here and kept in sync.
VITE_WS_URL=wss://football-trivia-ws.onrender.com
VITE_ADMOB_BANNER_ID=ca-app-pub-7656537208669381/4747760334
